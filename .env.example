# Zeka Tech Backend Configuration

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-12345

# Admin Configuration
ADMIN_EMAIL=admin@zakatech.com
ADMIN_PASSWORD=admin123

# PostgreSQL Database URL (Required for Vercel/Supabase)
# Format: postgres://username:password@host:port/database
# For Supabase: postgres://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://localhost:5432/zeka_tech

# Alternative: Supabase connection details
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-key
