{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "index.html",
          "admin.html",
          "style.css",
          "popup-styles.css",
          "script.js",
          "api-client.js",
          "admin.js",
          "images/**",
          "sounds/**",
          "database.js",
          "middleware/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
